model profiles {
  id           String   @id @db.Uuid
  display_name String
  photo_url    String?
  bio          String?
  points       Int?     @default(0)
  level        Int?     @default(1)
  updated_at   DateTime @default(dbgenerated("timezone('utc'::text, now())")) @db.Timestamptz(6)
  users        users    @relation(fields: [id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("bodhy_db")
}